{
  "name": "varia",
  "version": "0.2.1",
  "type": "module",
  "private": false,
  "description": "A deterministic claim-provenance engine for Wikipedia page histories. Evidence, not truth.",
  "repository": "github:nextconsensus/var-ia",
  "homepage": "https://nextconsensus.com",
  "bugs": "https://github.com/nextconsensus/var-ia/issues",
  "keywords": [
    "wikipedia",
    "evidence-graph",
    "claim-provenance",
    "diff-analysis",
    "edit-history",
    "deterministic",
    "observation-engine"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0",
  "workspaces": [
    "packages/ingestion",
    "packages/evidence-graph",
    "packages/analyzers",
    "packages/interpreter",
    "packages/cli",
    "packages/persistence",
    "packages/eval",
    "packages/observable"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "biome lint packages/",
    "format": "biome format --write packages/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
