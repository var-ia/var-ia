# Varia model provider API keys (optional)
# Set the key for the provider you use with --model <provider>
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# BYOK_API_KEY=sk-...

# MediaWiki auth (optional, for private wikis)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# Notifications (optional, for watch/cron commands)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SMTP_TO=alerts@example.com
